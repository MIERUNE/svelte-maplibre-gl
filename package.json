{
	"name": "@svelte-maplibre-gl/docs",
	"version": "1.0.0",
	"private": true,
	"type": "module",
	"license": "(MIT OR Apache-2.0)",
	"description": "Documentation website for svelte-maplibre-gl",
	"repository": {
		"url": "https://github.com/MIERUNE/svelte-maplibre-gl"
	},
	"homepage": "https://svelte-maplibre-gl.mierune.dev/",
	"scripts": {
		"dev": "pnpm build:packages && vite dev",
		"dev:maplibre-next": "node scripts/with-maplibre-version.mjs next pnpm run dev",
		"build": "pnpm build:packages && vite build",
		"build:all": "turbo run build",
		"build:packages": "turbo run build --filter='./svelte-maplibre-gl' --filter='./extensions/*'",
		"build:maplibre-next": "node scripts/with-maplibre-version.mjs next pnpm run build:packages",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:all": "turbo run check",
		"check:maplibre-next": "node scripts/with-maplibre-version.mjs next pnpm run check:all",
		"check:watch": "turbo run check:watch --filter='./svelte-maplibre-gl' --filter='./extensions/*'",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"test:unit": "vitest",
		"test:unit:maplibre-next": "node scripts/with-maplibre-version.mjs next pnpm run test:unit -- --run",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright test",
		"changeset": "changeset",
		"version": "changeset version",
		"release": "pnpm build:packages && changeset publish"
	},
	"dependencies": {
		"@svelte-maplibre-gl/contour": "workspace:*",
		"@svelte-maplibre-gl/deckgl": "workspace:*",
		"@svelte-maplibre-gl/pmtiles": "workspace:*",
		"@svelte-maplibre-gl/terradraw": "workspace:*",
		"svelte-maplibre-gl": "workspace:*"
	},
	"devDependencies": {
		"@changesets/changelog-github": "^0.7.0",
		"@changesets/cli": "^2.31.0",
		"@deck.gl/core": "catalog:",
		"@deck.gl/layers": "catalog:",
		"@deck.gl/mapbox": "catalog:",
		"@docsearch/css": "^4.6.3",
		"@docsearch/js": "^4.6.3",
		"@eslint/js": "^10.0.1",
		"@internationalized/date": "^3.12.2",
		"@lucide/svelte": "^1.23.0",
		"@playwright/test": "^1.61.1",
		"@sveltejs/adapter-cloudflare": "^7.2.9",
		"@sveltejs/kit": "catalog:",
		"@sveltejs/package": "catalog:",
		"@sveltejs/vite-plugin-svelte": "catalog:",
		"@tailwindcss/typography": "^0.5.20",
		"@tailwindcss/vite": "^4.3.2",
		"@types/geojson": "catalog:",
		"@types/node": "^25.9.4",
		"@types/three": "^0.184.1",
		"bits-ui": "^2.18.1",
		"clsx": "^2.1.1",
		"eslint": "^10.6.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.20.0",
		"fast-png": "^8.0.0",
		"globals": "^17.7.0",
		"install": "^0.13.0",
		"maplibre-contour": "catalog:",
		"maplibre-gl": "catalog:",
		"mdsvex": "^0.12.7",
		"mode-watcher": "^1.1.0",
		"pathe": "^2.0.3",
		"pkg-pr-new": "^0.0.71",
		"pmtiles": "catalog:",
		"prettier": "^3.9.4",
		"prettier-plugin-svelte": "^3.5.2",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"publint": "catalog:",
		"shiki": "^4.3.1",
		"superjson": "^2.2.6",
		"svelte": "catalog:",
		"svelte-check": "catalog:",
		"svelte2tsx": "0.7.55",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.3.2",
		"tailwindcss-animate": "^1.0.7",
		"terra-draw": "catalog:",
		"terra-draw-maplibre-gl-adapter": "1.3.0",
		"three": "^0.184.0",
		"turbo": "^2.10.3",
		"typescript": "catalog:",
		"typescript-eslint": "^8.62.1",
		"vite": "catalog:",
		"vitest": "^4.1.9"
	},
	"packageManager": "pnpm@10.15.0",
	"pnpm": {
		"overrides": {
			"svelte2tsx": "0.7.55",
			"terra-draw-maplibre-gl-adapter": "1.3.0"
		}
	}
}
